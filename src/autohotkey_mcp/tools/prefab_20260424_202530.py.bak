"""Prefab UI tools for autohotkey-mcp — rich prefab-ui 0.19.1 surfaces.

Six @mcp.tool(app=True) tools:

  show_scriptlets_card         — DataTable: all scriptlets, Dot status, Badge category
  show_running_scriptlets_card — Dashboard metrics + DataTable of live instances
  show_ahk_help_card           — Tabs per help level, Markdown rendering
  show_scriptlet_detail_card   — Code block + Badge metadata + Kbd hotkey chips
  show_generation_result_card  — generated script Code block + Badge row
  show_server_status_card      — Dashboard KPIs + config DataTable

All components built with context manager pattern (the only safe approach with
prefab-ui's ContextVar-based child tracking).

Registration controlled by AUTOHOTKEY_PREFAB_APPS env (0 = skip, default on).
"""

from __future__ import annotations

import logging
import os
from pathlib import Path
from typing import Any

import httpx
from fastmcp import FastMCP
from fastmcp.tools import ToolResult
from prefab_ui.app import PrefabApp
from prefab_ui.components import (
    Badge,
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
    Code,
    Column,
    Dashboard,
    DashboardItem,
    DataTable,
    DataTableColumn,
    Dot,
    H3,
    Kbd,
    Markdown,
    Metric,
    Muted,
    Row,
    Separator,
    Tab,
    Tabs,
    Text,
)

logger = logging.getLogger(__name__)

BRIDGE_URL = os.getenv("AUTOHOTKEY_BRIDGE_URL", "http://127.0.0.1:10744").rstrip("/")
DEPOT = Path(os.getenv("AUTOHOTKEY_SCRIPT_DEPOT", "d:/dev/repos/autohotkey-test"))
PORT = os.getenv("PORT", "10746")

_CAT_VARIANT: dict[str, str] = {
    "hotkeys": "default",
    "gui": "info",
    "clipboard": "secondary",
    "files": "warning",
    "windows": "outline",
    "strings": "secondary",
    "system": "destructive",
    "productivity": "success",
    "games": "info",
    "testing": "warning",
    "network": "outline",
    "ai_generated": "success",
    "general": "secondary",
}


def _prefab_enabled() -> bool:
    return os.getenv("AUTOHOTKEY_PREFAB_APPS", "1").lower() not in ("0", "false", "no")


def _cat_badge(cat: str) -> Badge:
    variant = _CAT_VARIANT.get((cat or "general").lower(), "secondary")
    return Badge(cat or "general", variant=variant)


def _status_dot(running: bool) -> Dot:
    return Dot(variant="success" if running else "muted", size="sm")


def _plain_dot(running: bool) -> str:
    return "● " if running else "○ "


def register_prefab_tools(mcp: FastMCP) -> None:
    """Register Prefab App tools. Skipped when AUTOHOTKEY_PREFAB_APPS=0."""

    if not _prefab_enabled():
        logger.info("AUTOHOTKEY_PREFAB_APPS=0 — skipping Prefab tool registration")
        return

    from autohotkey_mcp.tools.scriptlets import (
        _bridge_get,
        _depot_path,
        _enrich_scriptlet_categories,
        _find_ahk_exe,
        _list_scriptlets_direct,
        _read_metadata,
        get_running_overview,
    )
    from autohotkey_mcp import help_content

    # ──────────────────────────────────────────────────────────────────────────
    # 1. ALL SCRIPTLETS — DataTable
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_scriptlets_card() -> ToolResult:
        """
        Show all AutoHotkey scriptlets as a rich Prefab card.
        DataTable with Dot running indicator, Badge category, sortable ID, search, pagination.
        Uses bridge when available; falls back to depot scan.
        """
        try:
            data = await _bridge_get("/scriptlets")
            raw = data if isinstance(data, list) else (
                data.get("scriptlets", []) if isinstance(data, dict) else []
            )
            items = _enrich_scriptlet_categories(raw if isinstance(raw, list) else [])
            source = "bridge"
        except Exception:
            items = _list_scriptlets_direct()
            source = "depot"

        total = len(items)
        running_count = sum(1 for s in items if s.get("running"))

        plain = f"AutoHotkey Scriptlets — {total} total, {running_count} running [{source}]\n"
        for s in items:
            plain += (
                f"{_plain_dot(bool(s.get('running')))}"
                f"{s.get('id','?')}  [{s.get('category','general')}]  "
                f"{(s.get('description') or '')[:70]}\n"
            )

        rows: list[dict[str, Any]] = []
        for s in items:
            rows.append({
                "status": _status_dot(bool(s.get("running"))),
                "id": s.get("id") or "?",
                "category": _cat_badge(s.get("category") or "general"),
                "description": (s.get("description") or "")[:90],
            })

        with Column(gap=2) as view:
            with Card(css_class="w-full"):
                with CardHeader():
                    with Row(gap=2, align="center"):
                        CardTitle("AutoHotkey Scriptlets")
                        Badge(f"{running_count} running", variant="success")
                        Badge(f"{total} total", variant="secondary")
                    CardDescription(f"Source: {source}  ·  depot: {DEPOT}")
                with CardContent():
                    DataTable(
                        columns=[
                            DataTableColumn(key="status", header="", width="44px"),
                            DataTableColumn(key="id", header="ID", sortable=True),
                            DataTableColumn(key="category", header="Category", sortable=True, width="130px"),
                            DataTableColumn(key="description", header="Description"),
                        ],
                        rows=rows,
                        search=True,
                        paginated=True,
                        page_size=20,
                    )

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title="AHK Scriptlets"),
        )

    # ──────────────────────────────────────────────────────────────────────────
    # 2. RUNNING SCRIPTLETS — Dashboard KPIs + DataTable
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_running_scriptlets_card() -> ToolResult:
        """
        Show currently running AutoHotkey scriptlets as a rich Prefab card.
        Dashboard with Metric tiles (total, direct PIDs, bridge) and a DataTable of live instances.
        """
        data = await get_running_overview()
        instances: list[dict[str, Any]] = data.get("instances", [])
        count = len(instances)
        direct_count = sum(1 for i in instances if i.get("source") == "direct")
        bridge_count = sum(1 for i in instances if i.get("source") == "bridge")

        if count == 0:
            plain = "No AutoHotkey scriptlets currently running."
        else:
            lines = [f"Running: {count}  (direct: {direct_count}, bridge: {bridge_count})"]
            for inst in instances:
                pid_str = f" PID {inst['pid']}" if inst.get("pid") else ""
                lines.append(
                    f"● {inst.get('script_id','?')}{pid_str}"
                    f"  [{inst.get('source','?')}]"
                    f"  {inst.get('hotkeys','')}"
                    f"  {(inst.get('description') or '')[:60]}"
                )
            plain = "\n".join(lines)

        rows: list[dict[str, Any]] = []
        for inst in instances:
            src = inst.get("source") or "?"
            rows.append({
                "script_id": inst.get("script_id") or "?",
                "pid": str(inst["pid"]) if inst.get("pid") else "—",
                "source": Badge(src, variant="info" if src == "bridge" else "default"),
                "hotkeys": inst.get("hotkeys") or "",
                "description": (inst.get("description") or "")[:80],
            })

        with Column(gap=3) as view:
            # KPI row
            with Dashboard(columns=3, row_height=90):
                with DashboardItem(col=1, row=1, col_span=1):
                    Metric(label="Running", value=count)
                with DashboardItem(col=2, row=1, col_span=1):
                    Metric(label="Direct (PID)", value=direct_count)
                with DashboardItem(col=3, row=1, col_span=1):
                    Metric(label="Bridge", value=bridge_count)
            # Instance table
            with Card(css_class="w-full"):
                with CardHeader():
                    with Row(gap=2, align="center"):
                        CardTitle("Live Instances")
                        Badge(str(count), variant="success" if count > 0 else "secondary")
                with CardContent():
                    if count == 0:
                        Text("No scriptlets currently running.")
                    else:
                        DataTable(
                            columns=[
                                DataTableColumn(key="script_id", header="Script ID", sortable=True),
                                DataTableColumn(key="pid", header="PID", width="80px", align="right"),
                                DataTableColumn(key="source", header="Source", width="100px"),
                                DataTableColumn(key="hotkeys", header="Hotkeys", width="150px"),
                                DataTableColumn(key="description", header="Description"),
                            ],
                            rows=rows,
                        )

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title="Running AHK Scriptlets"),
        )

    # ──────────────────────────────────────────────────────────────────────────
    # 3. HELP — Tabs + Markdown
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_ahk_help_card(level: str = "quick") -> ToolResult:
        """
        Show AutoHotkey v2 help as a rich Prefab card.
        Tabs for all six levels (quick/reference/language/usage/tools/mcp_server),
        each rendered as Markdown. level sets the initially active tab.
        """
        levels = list(help_content.LEVELS.keys())
        active = level if level in levels else "quick"
        plain = f"AHK Help [{active}]\n\n{help_content.get_help(level=active)}"

        with Card(css_class="w-full") as view:
            with CardHeader():
                CardTitle("AutoHotkey v2 Help")
                CardDescription("Six reference levels — click tabs to switch")
            with CardContent():
                with Tabs(value=active, variant="line"):
                    for lv in levels:
                        with Tab(lv):
                            Markdown(help_content.get_help(level=lv))

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title=f"AHK Help: {active}"),
        )

    # ──────────────────────────────────────────────────────────────────────────
    # 4. SINGLE SCRIPTLET DETAIL — Code + Badges + Kbd
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_scriptlet_detail_card(script_id: str) -> ToolResult:
        """
        Show a single AutoHotkey scriptlet as a rich Prefab card.
        Full source in a Code block with syntax highlighting, metadata Badges,
        and individual Kbd chips for each hotkey.
        script_id: scriptlet id without .ahk extension
        """
        script_id = script_id.strip().removesuffix(".ahk")
        path = _depot_path(script_id)

        if not path.exists():
            plain = f"Scriptlet '{script_id}' not found in depot."
            with Card() as view:
                with CardContent():
                    Text(plain)
            return ToolResult(content=plain, structured_content=PrefabApp(view=view, title="Not Found"))

        meta = _read_metadata(path)
        source = path.read_text(encoding="utf-8", errors="replace")
        name = meta.get("name") or script_id
        desc = meta.get("description") or ""
        version = meta.get("version") or ""
        category = meta.get("category") or "general"
        hotkeys_raw = meta.get("hotkeys") or meta.get("hotkey") or ""
        hotkeys = [h.strip() for h in hotkeys_raw.replace(",", " ").split() if h.strip()]
        extra_meta = {
            k: v for k, v in meta.items()
            if k not in ("hotkeys", "hotkey", "name", "description", "category", "version")
        }

        plain = (
            f"{name} [{category}]{f'  v{version}' if version else ''}\n"
            f"{desc}\nHotkeys: {hotkeys_raw or 'none'}\n\n{source[:800]}"
        )

        with Card(css_class="w-full") as view:
            with CardHeader():
                with Row(gap=2, align="center"):
                    CardTitle(name)
                    _cat_badge(category)
                    if version:
                        Badge(f"v{version}", variant="outline")
                if desc:
                    CardDescription(desc)
            with CardContent():
                with Column(gap=3):
                    # Hotkey chips
                    with Row(gap=2, align="center"):
                        Muted("Hotkeys:")
                        if hotkeys:
                            with Row(gap=1):
                                for h in hotkeys:
                                    Kbd(h)
                        else:
                            Muted("none")
                    Separator(spacing=1)
                    # Extra metadata as compact badges
                    if extra_meta:
                        with Row(gap=2):
                            for k, v in extra_meta.items():
                                Badge(f"{k}: {v}", variant="outline")
                    Separator(spacing=1)
                    H3("Source")
                    Code(source, language="autohotkey")

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title=f"AHK: {name}"),
        )

    # ──────────────────────────────────────────────────────────────────────────
    # 5. GENERATION RESULT — Code + Badges + warning
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_generation_result_card(script_id: str) -> ToolResult:
        """
        Show a freshly generated scriptlet from ai_generated/ as a rich Prefab card.
        Source in a Code block with metadata Badges and a safety warning.
        Use immediately after generate_scriptlet returns a script_id.
        script_id: stem returned by generate_scriptlet (without .ahk)
        """
        script_id = script_id.strip().removesuffix(".ahk")
        ai_path = DEPOT / "scriptlets" / "ai_generated" / f"{script_id}.ahk"
        fallback = DEPOT / "scriptlets" / f"{script_id}.ahk"
        path = ai_path if ai_path.exists() else (fallback if fallback.exists() else None)

        if path is None:
            plain = f"Generated scriptlet '{script_id}' not found. Run generate_scriptlet first."
            with Card() as view:
                with CardContent():
                    Text(plain)
            return ToolResult(content=plain, structured_content=PrefabApp(view=view, title="Not Found"))

        meta = _read_metadata(path)
        source = path.read_text(encoding="utf-8", errors="replace")
        name = meta.get("name") or script_id
        desc = meta.get("description") or ""
        category = meta.get("category") or "ai_generated"
        version = meta.get("version") or "1.0.0"
        hotkeys_raw = meta.get("hotkeys") or meta.get("hotkey") or ""
        hotkeys = [h.strip() for h in hotkeys_raw.replace(",", " ").split() if h.strip()]
        is_ai = "ai_generated" in str(path)

        plain = (
            f"Generated: {name}\nCategory: {category}  Version: {version}\n"
            f"Path: {path}\n\n{desc}\n\n{source[:600]}..."
        )

        with Card(css_class="w-full") as view:
            with CardHeader():
                with Row(gap=2, align="center"):
                    CardTitle(f"Generated: {name}")
                    _cat_badge(category)
                    Badge(f"v{version}", variant="outline")
                    if is_ai:
                        Badge("AI Generated", variant="success")
                if desc:
                    CardDescription(desc)
            with CardContent():
                with Column(gap=3):
                    # Path + hotkeys
                    with Row(gap=2, align="center"):
                        Muted("Saved to:")
                        Text(str(path))
                    if hotkeys:
                        with Row(gap=2, align="center"):
                            Muted("Hotkeys:")
                            with Row(gap=1):
                                for h in hotkeys:
                                    Kbd(h)
                    Separator(spacing=1)
                    # Safety warning
                    with Card(css_class="border-yellow-400 bg-yellow-50 dark:bg-yellow-950"):
                        with CardContent():
                            Text(
                                "⚠ Review before moving to main scriptlets/. "
                                "Untrusted scripts can harm your machine."
                            )
                    Separator(spacing=1)
                    H3("Generated Source")
                    Code(source, language="autohotkey")

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title=f"Generated: {name}"),
        )

    # ──────────────────────────────────────────────────────────────────────────
    # 6. SERVER STATUS — Dashboard KPIs + config DataTable
    # ──────────────────────────────────────────────────────────────────────────

    @mcp.tool(app=True)
    async def show_server_status_card() -> ToolResult:
        """
        Show autohotkey-mcp server status as a rich Prefab card.
        Dashboard with Metric tiles (scriptlet count, running count, bridge status, AHK exe)
        and a configuration DataTable (ports, depot, env flags).
        """
        items = _list_scriptlets_direct()
        total = len(items)
        running_count = sum(1 for s in items if s.get("running"))

        bridge_up = False
        bridge_error = ""
        try:
            async with httpx.AsyncClient() as client:
                r = await client.get(f"{BRIDGE_URL}/scriptlets", timeout=2.0)
                bridge_up = r.status_code < 400
        except Exception as e:
            bridge_error = str(e)[:60]

        ahk_exe = _find_ahk_exe() or "not found"
        ahk_found = ahk_exe != "not found"

        plain = (
            f"autohotkey-mcp Status\n"
            f"Port: {PORT}  Bridge: {'UP' if bridge_up else 'DOWN'}  ({BRIDGE_URL})\n"
            f"Scriptlets: {total}  Running: {running_count}\n"
            f"Depot: {DEPOT}\n"
            f"AHK exe: {ahk_exe}\n"
        )

        config_rows = [
            {"setting": "MCP Port", "value": PORT},
            {"setting": "Bridge URL", "value": BRIDGE_URL},
            {"setting": "Bridge Status", "value": "UP" if bridge_up else f"DOWN — {bridge_error}"},
            {"setting": "Script Depot", "value": str(DEPOT)},
            {"setting": "AHK Executable", "value": ahk_exe},
            {"setting": "LLM Base URL", "value": os.getenv("AUTOHOTKEY_LLM_BASE_URL", "not set")},
            {"setting": "LLM Model", "value": os.getenv("AUTOHOTKEY_LLM_MODEL", "not set")},
            {"setting": "Prefab Apps", "value": os.getenv("AUTOHOTKEY_PREFAB_APPS", "1 (on)")},
        ]

        with Column(gap=3) as view:
            # KPI row — 4 tiles across
            with Dashboard(columns=4, row_height=90):
                with DashboardItem(col=1, row=1, col_span=1):
                    Metric(label="Scriptlets", value=total)
                with DashboardItem(col=2, row=1, col_span=1):
                    Metric(label="Running", value=running_count)
                with DashboardItem(col=3, row=1, col_span=1):
                    with Card():
                        with CardContent():
                            with Column(gap=1):
                                Muted("Bridge")
                                Badge("UP", variant="success") if bridge_up else Badge("DOWN", variant="destructive")
                with DashboardItem(col=4, row=1, col_span=1):
                    with Card():
                        with CardContent():
                            with Column(gap=1):
                                Muted("AHK Exe")
                                Badge("found", variant="success") if ahk_found else Badge("missing", variant="destructive")
            # Config table
            with Card(css_class="w-full"):
                with CardHeader():
                    CardTitle("Configuration")
                with CardContent():
                    DataTable(
                        columns=[
                            DataTableColumn(key="setting", header="Setting", width="200px"),
                            DataTableColumn(key="value", header="Value"),
                        ],
                        rows=config_rows,
                        search=False,
                        paginated=False,
                    )

        return ToolResult(
            content=plain,
            structured_content=PrefabApp(view=view, title="AHK MCP Status"),
        )
